{"manifest_version":4,"short_name":"Notebook","name":"Javascript Notebook","version":"1.0","author":"Joshua M. Moore <joshua.moore@verticesandedges.net>","developer":{"name":"Joshua M. Moore","url":"https://github.com/mooreolith"},"homepage_url":"https://github.com/mooreolith/notebook","lang":"en","icons":[{"src":"/notebook/notebook.d83ecd71.png","sizes":"512x512","type":"image/png","purpose":"maskable"},{"src":"/notebook/notebook.d83ecd71.png","sizes":"512x512","type":"image/png","purpose":"any"}],"start_url":"http://localhost:8080/notebook/","scope":"/notebook/","display":"standalone","orientation":"any","background_color":"#ffffff","offline_enabled":true,"background":{"scripts":["service-worker.js"],"service_worker":["service-worker.js"]},"commands":{"run-cell":{"suggested_key":{"default":"Ctrl+Enter"},"description":"Execute or render the currently focused cell"}},"default_locale":"en","description":"A client-side Javascript Notebook","file_handlers":[{"action":"/notebook/?open-file","accept":{"application/x-ipynb+json":[".ipynb"]}}],"launch_handler":{"client_mode":"navigate-new"}}