{
  "name": "livebook",
  "version": "0.0.1",
  "description": "A JS/TS/MD notebook with live markdown fields",
  "keywords": [
    "js",
    "ts",
    "md"
  ],
  "license": "UNLICENSED",
  "author": "Joshua M. Moore <illogical.alliteration@gmail.com>",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "parcel src/index.html --dist-dir docs",
    "start": "http-server docs/",
    "build:folder": "parcel src/index.html --dist-dir docs/notebook/ --public-url /notebook/",
    "copy:folder": "cp -r ./examples/ ./docs/notebook/. && cp src/notebook/spiral-small.png ./docs/notebook/.",
    "start:folder": "http-server docs/",
    "build:github": "rm -rf .parcel-cache/ docs/* && cp src/notebook/spiral-small.png docs/. && cp -r examples/ docs/. && parcel src/index.html --dist-dir docs/ --public-url /notebook/"
  },
  "devDependencies": {
    "@parcel/packager-raw-url": "^2.16.4",
    "@parcel/transformer-inline-string": "^2.16.4",
    "@parcel/transformer-webmanifest": "^2.16.4",
    "parcel": "^2.16.4",
    "process": "^0.11.10"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/markdown": "^1.6.3",
    "@parcel/service-worker": "^2.16.4",
    "codemirror": "^6.0.2",
    "codemirror-live-markdown": "^0.5.1-alpha.1",
    "katex": "^0.16.45",
    "lowlight": "^3.3.0",
    "typescript": "^6.0.3"
  }
}
